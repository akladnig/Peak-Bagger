{
  "version": 8,
  "name": "Peak Bagger Tasmania Local Topo",
  "glyphs": "{fontstack}/{range}.pbf",
  "metadata": {
    "maputnik:renderer": "mbgljs",
    "peak-bagger:style-owner": "local_topo/tasmania"
  },
  "sources": {
    "tasmania-osm": {
      "type": "vector",
      "url": "mbtiles://{tasmania-osm}"
    },
    "tasmania-relief": {
      "type": "raster",
      "url": "mbtiles://{tasmania-relief}",
      "tileSize": 256
    },
    "tasmania-contours": {
      "type": "vector",
      "url": "mbtiles://{tasmania-contours}"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f5f0e4"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "tasmania-osm",
      "source-layer": "landcover",
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "wood",
          "#d9e6c3",
          "grass",
          "#e4ecc7",
          "scrub",
          "#d8dfba",
          "wetland",
          "#d7deca",
          "rock",
          "#ddd5c6",
          "#ebe6d6"
        ],
        "fill-opacity": 0.78
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "tasmania-osm",
      "source-layer": "landuse",
      "paint": {
        "fill-color": [
          "match",
          ["get", "class"],
          "park",
          "#d7e8bf",
          "forest",
          "#cedeb5",
          "residential",
          "#efe6d8",
          "farmland",
          "#efe8bf",
          "suburb",
          "#f1e7d9",
          "#ece3d4"
        ],
        "fill-opacity": 0.5
      }
    },
    {
      "id": "terrain-relief-shading",
      "type": "raster",
      "source": "tasmania-relief",
      "paint": {
        "raster-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6,
          0.18,
          10,
          0.24,
          14,
          0.31,
          16,
          0.36
        ],
        "raster-saturation": -1,
        "raster-contrast": 0.2,
        "raster-brightness-max": 0.92
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "tasmania-osm",
      "source-layer": "water",
      "paint": {
        "fill-color": "#9fd2f3",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "tasmania-osm",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#7fb8e6",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          0.4,
          14,
          1.2,
          16,
          1.8
        ]
      }
    },
    {
      "id": "contours",
      "type": "line",
      "source": "tasmania-contours",
      "source-layer": "contours",
      "minzoom": 12,
      "paint": {
        "line-color": "#8c6a43",
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          0.18,
          14,
          0.3,
          16,
          0.42
        ],
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          0.35,
          14,
          0.55,
          16,
          0.85
        ]
      }
    },
    {
      "id": "major-roads-casing",
      "type": "line",
      "source": "tasmania-osm",
      "source-layer": "transportation",
      "filter": [
        "match",
        ["get", "class"],
        ["motorway", "trunk", "primary", "secondary", "minor"],
        true,
        false
      ],
      "paint": {
        "line-color": "#f8f2e7",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6,
          0.8,
          10,
          1.4,
          12,
          2.2,
          14,
          3.2,
          16,
          4.6
        ]
      }
    },
    {
      "id": "major-roads",
      "type": "line",
      "source": "tasmania-osm",
      "source-layer": "transportation",
      "filter": [
        "match",
        ["get", "class"],
        ["motorway", "trunk", "primary", "secondary", "minor"],
        true,
        false
      ],
      "paint": {
        "line-color": [
          "match",
          ["get", "class"],
          "motorway",
          "#a26d43",
          "trunk",
          "#b07b4a",
          "primary",
          "#bf9154",
          "secondary",
          "#c9a26c",
          "#b69a76"
        ],
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6,
          0.4,
          10,
          0.9,
          12,
          1.8,
          14,
          2.4,
          16,
          2.6
        ]
      }
    },
    {
      "id": "access-roads",
      "type": "line",
      "source": "tasmania-osm",
      "source-layer": "transportation",
      "filter": [
        "any",
        ["==", ["get", "class"], "track"],
        [
          "all",
          ["==", ["get", "class"], "minor"],
          ["==", ["get", "surface"], "unpaved"]
        ],
        ["has", "service"]
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#8f744c",
        "line-dasharray": [3, 1.5],
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10,
          0.7,
          12,
          1.1,
          14,
          1.5,
          16,
          2
        ]
      }
    },
    {
      "id": "hiking-paths-casing",
      "type": "line",
      "source": "tasmania-osm",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "path"],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#f5f0e4",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          1.1,
          14,
          1.6,
          16,
          2.3
        ]
      }
    },
    {
      "id": "hiking-paths",
      "type": "line",
      "source": "tasmania-osm",
      "source-layer": "transportation",
      "filter": ["==", ["get", "class"], "path"],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#5d5f3b",
        "line-dasharray": [0.4, 1.3],
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          0.45,
          14,
          0.75,
          16,
          1.15
        ]
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "tasmania-osm",
      "source-layer": "place",
      "minzoom": 6,
      "filter": [
        "match",
        ["get", "class"],
        ["city", "town", "village", "hamlet", "suburb", "locality", "island"],
        true,
        false
      ],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Roboto Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6,
          10,
          10,
          11,
          14,
          13
        ]
      },
      "paint": {
        "text-color": "#5d4b32",
        "text-halo-color": "rgba(245, 240, 228, 0.86)",
        "text-halo-width": 1
      }
    },
    {
      "id": "water-name-labels",
      "type": "symbol",
      "source": "tasmania-osm",
      "source-layer": "water_name",
      "minzoom": 8,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Roboto Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          10,
          12,
          11,
          14,
          12
        ]
      },
      "paint": {
        "text-color": "#3e79a6",
        "text-halo-color": "rgba(245, 240, 228, 0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "waterway-labels",
      "type": "symbol",
      "source": "tasmania-osm",
      "source-layer": "waterway",
      "minzoom": 12,
      "filter": ["has", "name"],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["Roboto Regular"],
        "text-size": 10
      },
      "paint": {
        "text-color": "#4a89b3",
        "text-halo-color": "rgba(245, 240, 228, 0.8)",
        "text-halo-width": 1
      }
    },
    {
      "id": "road-labels",
      "type": "symbol",
      "source": "tasmania-osm",
      "source-layer": "transportation_name",
      "minzoom": 11,
      "filter": [
        "match",
        ["get", "class"],
        ["motorway", "trunk", "primary", "secondary", "minor"],
        true,
        false
      ],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["Roboto Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          11,
          10,
          14,
          11
        ]
      },
      "paint": {
        "text-color": "#6a5a41",
        "text-halo-color": "rgba(248, 242, 231, 0.92)",
        "text-halo-width": 1.1
      }
    },
    {
      "id": "path-labels",
      "type": "symbol",
      "source": "tasmania-osm",
      "source-layer": "transportation_name",
      "minzoom": 13,
      "filter": [
        "match",
        ["get", "class"],
        ["path", "track"],
        true,
        false
      ],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["Roboto Regular"],
        "text-size": 10
      },
      "paint": {
        "text-color": "#4d4c36",
        "text-halo-color": "rgba(248, 242, 231, 0.92)",
        "text-halo-width": 1
      }
    }
  ]
}
